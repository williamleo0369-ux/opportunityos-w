# The web app proxies /api to this server-side origin, keeping session cookies same-origin.
OPPORTUNITY_OS_API_ORIGIN=http://127.0.0.1:8000
# Only set this for a deliberately separate public API origin with HTTPS/CORS cookies configured.
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com
OPPORTUNITY_OS_DATABASE_URL=sqlite:////Users/your-name/.opportunity-os/opportunity-os.db
# OPPORTUNITY_OS_DATABASE_URL=postgresql://opportunity:opportunity@127.0.0.1:5432/opportunity_os
REDIS_URL=redis://localhost:6379/0
OPPORTUNITY_OS_TASK_QUEUE=local
# OPPORTUNITY_OS_TASK_QUEUE=celery
OPPORTUNITY_OS_SEARCH_WORKERS=2
OPPORTUNITY_OS_DEFAULT_SEARCH_QUOTA_DAILY=20
OPPORTUNITY_OS_DEFAULT_REPORT_QUOTA_MONTHLY=100
OPPORTUNITY_OS_SESSION_TTL_DAYS=30
# Comma-separated emails that become admins when they register.
OPPORTUNITY_OS_ADMIN_EMAILS=
# Keep this stable: it signs sessions and encrypts account-level source credentials.
# OPPORTUNITY_OS_AUTH_SECRET=replace-with-a-long-production-secret
# OPPORTUNITY_OS_SECURE_COOKIES=true
# OPPORTUNITY_OS_COOKIE_SAMESITE=none
# OPPORTUNITY_OS_CORS_ORIGINS=https://app.example.com
OPPORTUNITY_OS_LLM_TIMEOUT_SECONDS=25
OPPORTUNITY_OS_AGENT_PARALLELISM=1
OPPORTUNITY_OS_LLM_PROVIDER=auto
# Optional token-rate metadata used only for cost estimates in Agent Run traces.
# OPPORTUNITY_OS_LLM_INPUT_USD_PER_MILLION=0
# OPPORTUNITY_OS_LLM_OUTPUT_USD_PER_MILLION=0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-5
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/anthropic
